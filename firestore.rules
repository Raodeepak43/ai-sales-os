rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Users ─────────────────────────────────────────────────
    // Public read (Link-in-Bio), only owner can write
    match /users/{userId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // ── Leads ─────────────────────────────────────────────────
    // Public create (chat is public), only owner can read/update
    match /leads/{leadId} {
      allow create: if true;
      allow read, update: if request.auth != null
        && resource.data.userId == request.auth.uid;
      allow delete: if false;
    }

    // ── Messages ──────────────────────────────────────────────
    // Public create (chat is public), only owner can read
    match /messages/{messageId} {
      allow create: if true;
      allow read: if request.auth != null
        && resource.data.userId == request.auth.uid;
      allow update, delete: if false;
    }

    // ── Payments ──────────────────────────────────────────────
    // Public create (from Razorpay callback), owner-only read
    match /payments/{paymentId} {
      allow create: if true;
      allow read: if request.auth != null
        && resource.data.userId == request.auth.uid;
      allow update, delete: if false;
    }

    // ── Bookings ──────────────────────────────────────────────
    match /bookings/{bookingId} {
      allow create, read, update, delete: if request.auth != null
        && (resource == null || resource.data.userId == request.auth.uid);
    }

    // ── Email campaigns ───────────────────────────────────────
    match /campaigns/{campaignId} {
      allow create, read, update, delete: if request.auth != null
        && (resource == null || resource.data.userId == request.auth.uid);
    }

    // ── Email subscribers ─────────────────────────────────────
    // Allow public subscribe (from link-in-bio), owner reads
    match /emails/{emailId} {
      allow create: if true;
      allow read, update, delete: if request.auth != null
        && resource.data.userId == request.auth.uid;
    }

    // ── Social auto-replies ───────────────────────────────────
    match /autoReplies/{ruleId} {
      allow create, read, update, delete: if request.auth != null
        && (resource == null || resource.data.userId == request.auth.uid);
    }

    // ── Notifications ─────────────────────────────────────────
    match /notifications/{notifId} {
      allow create, read, update, delete: if request.auth != null
        && (resource == null || resource.data.userId == request.auth.uid);
    }

    // ── Courses ───────────────────────────────────────────────
    // Published courses readable publicly (for student access)
    match /courses/{courseId} {
      allow read: if resource.data.published == true || (request.auth != null && resource.data.userId == request.auth.uid);
      allow create, update, delete: if request.auth != null
        && (resource == null || resource.data.userId == request.auth.uid);
    }
  }
}